<?php

/**
 * @file
 * Dynamic Form module — routes, permissions, and general helpers.
 */

/**
 * Implements hook_init().
 *
 * Loads jQuery Toast Plugin (CDN) and the DFBToast utility on every page
 * served by this module (dashboard/*, form/*, dynamic-form/* paths).
 */
function dynamic_form_init() {
  $path = current_path();
  if (
    strpos($path, 'dashboard')    === 0 ||
    strpos($path, 'form/')        === 0 ||
    strpos($path, 'dynamic-form/') === 0
  ) {
    $module_path = drupal_get_path('module', 'dynamic_form');
    drupal_add_css($module_path . '/css/toast.css');
    drupal_add_js($module_path . '/js/toast.js');
  }
}

/**
 * Returns an AJAX command array that triggers a DFBToast notification.
 *
 * @param string $type     One of: success, error, warning, info.
 * @param string $message  The message to display (already translated).
 *
 * @return array  AJAX command array for use in AJAX callbacks.
 */
function ajax_command_dfb_toast($type, $message) {
  return array(
    'command'    => 'dfbToast',
    'toast_type' => $type,
    'message'    => $message,
  );
}

/**
 * Implements hook_permission().
 */
function dynamic_form_permission()
{
  return array(
    'access dashboard' => array(
      'title' => t('Access dashboard'),
      'description' => t('Access the form builder dashboard.'),
    ),
    'view forms' => array(
      'title' => t('View forms'),
      'description' => t('Allow users to view and fill out forms.'),
    ),
    'create new form' => array(
      'title' => t('Create new form'),
      'description' => t('Create new forms.'),
    ),
    'edit any form' => array(
      'title' => t('Edit any form'),
      'description' => t('Edit any form.'),
    ),
    'edit own form' => array(
      'title' => t('Edit own form'),
      'description' => t('Edit own forms.'),
    ),
    'delete any form' => array(
      'title' => t('Delete any form'),
      'description' => t('Delete any form.'),
    ),
    'delete own form' => array(
      'title' => t('Delete own form'),
      'description' => t('Delete own forms.'),
    ),
    'view soft delete' => array(
      'title' => t('View soft deleted items'),
      'description' => t('Access the Trash page to view soft-deleted forms, sections, and questions.'),
    ),
    'restore deleted' => array(
      'title' => t('Restore deleted items'),
      'description' => t('Restore soft-deleted items from Trash or permanently remove them from the database.'),
    ),
    'view activity log' => array(
      'title' => t('View activity log'),
      'description' => t('Access the Activity Log page to see who created, edited, or deleted forms, sections, and questions.'),
    ),
  );
}

