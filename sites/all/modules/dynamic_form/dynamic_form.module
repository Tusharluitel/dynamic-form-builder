/**
 * Implements hook_theme().
 */
function dynamic_form_theme($existing, $type, $theme, $path)
{
  return array(
    'dynamic_form_dashboard' => array(
      'variables' => array('sidebar' => '', 'content' => ''),
      'template' => 'dashboard',
      'path' => drupal_get_path('theme', 'dynamic_form') . '/template',
    ),
  );
}

/* =====================================================================
   AUDIT LOG HELPER
   ===================================================================== */

/**
 * Appends one row to dynamic_form_audit_log.
 *
 * @param string     $entity_type  'form', 'section', or 'question'.
 * @param int        $entity_id    Primary key of the affected row.
 * @param string     $action       'created', 'updated', or 'deleted'.
 * @param array|null $old_value    State before the action (NULL for created).
 * @param array|null $new_value    State after the action (NULL for deleted).
 */
function _dynamic_form_audit_log($entity_type, $entity_id, $action, $old_value = NULL, $new_value = NULL) {
  global $user;
  db_insert('dynamic_form_audit_log')
    ->fields(array(
      'entity_type' => $entity_type,
      'entity_id'   => (int) $entity_id,
      'action'      => $action,
      'actor_uid'   => isset($user->uid) ? (int) $user->uid : 0,
      'old_value'   => $old_value !== NULL ? json_encode($old_value) : NULL,
      'new_value'   => $new_value !== NULL ? json_encode($new_value) : NULL,
      'ip_address'  => ip_address(),
      'created_at'  => REQUEST_TIME,
    ))
    ->execute();
}

/* =====================================================================
   FORM CRUD — ACCESS CALLBACKS
   ===================================================================== */

/**
 * Access callback for form/%/edit.
 *
 * Allows access if user has 'edit any form' or owns the form
 * and has 'edit own form'.
 */
function _dynamic_form_edit_access($form_id)
{
  global $user;

  if (user_access('edit any form')) {
    return TRUE;
  }

  if (user_access('edit own form')) {
    $created_by = db_select('dynamic_form_forms', 'f')
      ->fields('f', array('created_by'))
      ->condition('id', $form_id)
      ->condition('deleted_at', NULL, 'IS NULL')
      ->execute()
      ->fetchField();
    return $created_by && (int) $created_by === (int) $user->uid;
  }

  return FALSE;
}

/**
 * Access callback for form/%/delete.
 *
 * Allows access if user has 'delete any form' or owns the form
 * and has 'delete own form'.
 */
function _dynamic_form_delete_access($form_id)
{
  global $user;

  if (user_access('delete any form')) {
    return TRUE;
  }

  if (user_access('delete own form')) {
    $created_by = db_select('dynamic_form_forms', 'f')
      ->fields('f', array('created_by'))
      ->condition('id', $form_id)
      ->condition('deleted_at', NULL, 'IS NULL')
      ->execute()
      ->fetchField();
    return $created_by && (int) $created_by === (int) $user->uid;
  }

  return FALSE;
}

/* =====================================================================
   FORM CRUD — SLUG HELPER
   ===================================================================== */

/**
 * Generates a URL-friendly slug from a title.
 *
 * @param string $title
 *   The form title.
 *
 * @return string
 *   A lowercase, hyphenated slug.
 */
function _dynamic_form_generate_slug($title)
{
  // Lowercase, replace non-alphanumeric with hyphens, trim hyphens.
  $slug = drupal_strtolower($title);
  $slug = preg_replace('/[^a-z0-9]+/', '-', $slug);
  $slug = trim($slug, '-');

  // Ensure uniqueness by appending a number if needed.
  $base_slug = $slug;
  $counter = 1;
  while (db_select('dynamic_form_forms', 'f')
    ->fields('f', array('id'))
    ->condition('slug', $slug)
    ->condition('deleted_at', NULL, 'IS NULL')
    ->execute()
    ->fetchField()) {
    $slug = $base_slug . '-' . $counter;
    $counter++;
  }

  return $slug;
}

/* =====================================================================
   FORM ALTERS
   ===================================================================== */

/**
 * Implements hook_form_alter().
 */
function dynamic_form_form_alter(&$form, &$form_state, $form_id) {
  // Override the default Drupal login form error messages.
  if ($form_id == 'user_login' || $form_id == 'user_login_block') {
    $form['#validate'][] = 'dynamic_form_custom_login_error_override';
  }
}

/**
 * Custom validation handler to override the core login error message.
 */
function dynamic_form_custom_login_error_override($form, &$form_state) {
  if (!empty($_SESSION['messages']['error'])) {
    foreach ($_SESSION['messages']['error'] as $key => $message) {
      // Check if the message contains the default Drupal error string.
      if (strpos($message, 'Sorry, unrecognized username or password') !== FALSE) {
        $_SESSION['messages']['error'][$key] = t('Incorrect email or password for login.');
      }
    }
  }
}

/* =====================================================================
   FORM MEMBERS — QUEUE, MAIL, WORKER
   ===================================================================== */

/**
 * Implements hook_cron_queue_info().
 */
function dynamic_form_cron_queue_info() {
  return array(
    'dynamic_form_member_notify' => array(
      'worker callback' => 'dynamic_form_member_notify_worker',
      'time'            => 30,
    ),
  );
}

/**
 * Queue worker: sends a member-added notification email.
 *
 * @param array $item  Keyed array with form_id, form_title, user_id, role, form_url.
 */
function dynamic_form_member_notify_worker(array $item) {
  module_load_include('inc', 'dynamic_form', 'includes/dynamic_form.members');
  _dynamic_form_send_member_notification($item);
}

/**
 * Implements hook_mail().
 */
function dynamic_form_mail($key, &$message, $params) {
  $language = $message['language'];
  $options  = array('langcode' => $language->language);

  switch ($key) {
    case 'member_added':
      $message['subject'] = t(
        'You have been added to the form: @title',
        array('@title' => $params['form_title']),
        $options
      );
      $message['body'][] = t('Hi @name,', array('@name' => $params['user_name']), $options);
      $message['body'][] = '';
      $message['body'][] = t(
        'You have been added as @role to the form "@title".',
        array('@role' => $params['role_label'], '@title' => $params['form_title']),
        $options
      );
      if (!empty($params['form_url'])) {
        $message['body'][] = '';
        $message['body'][] = t(
          'Access the form here: @url',
          array('@url' => $params['form_url']),
          $options
        );
      }
      $message['body'][] = '';
      $message['body'][] = t('This is an automated notification. Please do not reply to this email.', array(), $options);
      break;
  }
}
