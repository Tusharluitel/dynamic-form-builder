<?php

/**
 * @file
 * Dynamic Form module — routes, permissions, and general helpers.
 */

/**
 * Implements hook_permission().
 */
function dynamic_form_permission()
{
  return array(
    'access dashboard' => array(
      'title' => t('Access dashboard'),
      'description' => t('Access the form builder dashboard.'),
    ),
    'view forms' => array(
      'title' => t('View forms'),
      'description' => t('Allow users to view and fill out forms.'),
    ),
    'create new form' => array(
      'title' => t('Create new form'),
      'description' => t('Create new forms.'),
    ),
    'edit any form' => array(
      'title' => t('Edit any form'),
      'description' => t('Edit any form.'),
    ),
    'edit own form' => array(
      'title' => t('Edit own form'),
      'description' => t('Edit own forms.'),
    ),
    'delete any form' => array(
      'title' => t('Delete any form'),
      'description' => t('Delete any form.'),
    ),
    'delete own form' => array(
      'title' => t('Delete own form'),
      'description' => t('Delete own forms.'),
    ),
  );
}

/**
 * Implements hook_menu().
 */
function dynamic_form_menu()
{
  $items = array();

  // Authentication routes.
  $items['login'] = array(
    'title' => 'Sign In',
    'page callback' => 'dynamic_form_login_page',
    'access callback' => 'user_is_anonymous',
    'file' => 'includes/dynamic_form.auth.inc',
    'type' => MENU_CALLBACK,
  );

  $items['register'] = array(
    'title' => 'Create Account',
    'page callback' => 'dynamic_form_register_page',
    'access callback' => 'user_is_anonymous',
    'file' => 'includes/dynamic_form.auth.inc',
    'type' => MENU_CALLBACK,
  );

  // Form CRUD routes.
  $items['form/create'] = array(
    'title' => 'Create Form',
    'page callback' => 'drupal_get_form',
    'page arguments' => array('dynamic_form_create_form'),
    'access arguments' => array('create new form'),
    'file' => 'includes/dynamic_form.forms.inc',
    'type' => MENU_CALLBACK,
  );

  $items['form/list'] = array(
    'title' => 'My Forms',
    'page callback' => 'dynamic_form_list_page',
    'access arguments' => array('view forms'),
    'file' => 'includes/dynamic_form.forms.inc',
    'type' => MENU_CALLBACK,
  );

  $items['form/%/edit'] = array(
    'title' => 'Edit Form',
    'page callback' => 'drupal_get_form',
    'page arguments' => array('dynamic_form_edit_form', 1),
    'access callback' => '_dynamic_form_edit_access',
    'access arguments' => array(1),
    'file' => 'includes/dynamic_form.forms.inc',
    'type' => MENU_CALLBACK,
  );

  $items['form/%/delete'] = array(
    'title' => 'Delete Form',
    'page callback' => 'drupal_get_form',
    'page arguments' => array('dynamic_form_delete_confirm', 1),
    'access callback' => '_dynamic_form_delete_access',
    'access arguments' => array(1),
    'file' => 'includes/dynamic_form.forms.inc',
    'type' => MENU_CALLBACK,
  );

  // Dashboard routes.
  $items['dashboard'] = array(
    'title' => 'Dashboard',
    'page callback' => 'dynamic_form_dashboard_page',
    'page arguments' => array('overview'),
    'access callback' => 'user_is_logged_in',
    'file' => 'includes/dynamic_form.dashboard.inc',
    'type' => MENU_CALLBACK,
  );

  $items['dashboard/forms'] = array(
    'title' => 'Forms',
    'page callback' => 'dynamic_form_dashboard_page',
    'page arguments' => array('forms'),
    'access callback' => 'user_is_logged_in',
    'file' => 'includes/dynamic_form.dashboard.inc',
    'type' => MENU_CALLBACK,
  );

  $items['dashboard/questions'] = array(
    'title' => 'Questions',
    'page callback' => 'dynamic_form_dashboard_page',
    'page arguments' => array('questions'),
    'access callback' => 'user_is_logged_in',
    'file' => 'includes/dynamic_form.dashboard.inc',
    'type' => MENU_CALLBACK,
  );

  $items['dashboard/sections'] = array(
    'title' => 'Sections',
    'page callback' => 'dynamic_form_dashboard_page',
    'page arguments' => array('sections'),
    'access callback' => 'user_is_logged_in',
    'file' => 'includes/dynamic_form.dashboard.inc',
    'type' => MENU_CALLBACK,
  );

  $items['dashboard/sections/create'] = array(
    'title' => 'Create Section',
    'page callback' => 'dynamic_form_dashboard_section_create_page',
    'access arguments' => array('create new form'), // Require ability to create forms
    'file' => 'includes/dynamic_form.dashboard.inc',
    'type' => MENU_CALLBACK,
  );

  $items['dashboard/sections/%/edit'] = array(
    'title' => 'Edit Section',
    'page callback' => 'dynamic_form_dashboard_section_edit_page',
    'page arguments' => array(2),
    // Reusing form edit access for now, but really should verify they can edit the parent form.
    // For simplicity, we'll allow 'edit any form' or we'll handle the ownership check in the form itself.
    'access arguments' => array('edit any form'),
    'file' => 'includes/dynamic_form.dashboard.inc',
    'type' => MENU_CALLBACK,
  );

  $items['dashboard/sections/%/delete'] = array(
    'title'            => 'Delete Section',
    'page callback'    => 'drupal_get_form',
    'page arguments'   => array('dynamic_form_delete_section_confirm', 2),
    'access arguments' => array('delete any form'),
    'file'             => 'includes/dynamic_form.sections.inc',
    'type'             => MENU_CALLBACK,
  );

  // Question edit / delete routes.
  $items['dashboard/questions/%/edit'] = array(
    'title'            => 'Edit Question',
    'page callback'    => 'dynamic_form_dashboard_question_edit_page',
    'page arguments'   => array(2),
    'access arguments' => array('edit any form'),
    'file'             => 'includes/dynamic_form.dashboard.inc',
    'type'             => MENU_CALLBACK,
  );

  $items['dashboard/questions/%/delete'] = array(
    'title'            => 'Delete Question',
    'page callback'    => 'drupal_get_form',
    'page arguments'   => array('dynamic_form_delete_question_confirm', 2),
    'access arguments' => array('delete any form'),
    'file'             => 'includes/dynamic_form.questions.inc',
    'type'             => MENU_CALLBACK,
  );

  $items['dashboard/forms/create'] = array(
    'title' => 'Create Form',
    'page callback' => 'dynamic_form_dashboard_form_create_page',
    'access arguments' => array('create new form'),
    'file' => 'includes/dynamic_form.dashboard.inc',
    'type' => MENU_CALLBACK,
  );

  $items['dashboard/forms/%/edit'] = array(
    'title' => 'Edit Form',
    'page callback' => 'dynamic_form_dashboard_form_edit_page',
    'page arguments' => array(2),
    'access callback' => '_dynamic_form_edit_access',
    'access arguments' => array(2),
    'file' => 'includes/dynamic_form.dashboard.inc',
    'type' => MENU_CALLBACK,
  );

  // Builder routes.
  $items['dashboard/forms/%/builder'] = array(
    'title' => 'Form Builder',
    'page callback' => 'dynamic_form_builder_page',
    'page arguments' => array(2),
    'access callback' => '_dynamic_form_edit_access',
    'access arguments' => array(2),
    'file' => 'includes/dynamic_form.builder.inc',
    'type' => MENU_CALLBACK,
  );

  $items['dynamic-form/ajax/builder/reorder'] = array(
    'page callback' => 'dynamic_form_ajax_reorder',
    'access callback' => 'user_is_logged_in',
    'file' => 'includes/dynamic_form.builder.inc',
    'type' => MENU_CALLBACK,
  );

  return $items;
}

/**
 * Implements hook_theme().
 */
function dynamic_form_theme($existing, $type, $theme, $path)
{
  return array(
    'dynamic_form_dashboard' => array(
      'variables' => array('sidebar' => '', 'content' => ''),
      'template' => 'dashboard',
      'path' => drupal_get_path('theme', 'dynamic_form') . '/template',
    ),
  );
}

/* =====================================================================
   FORM CRUD — ACCESS CALLBACKS
   ===================================================================== */

/**
 * Access callback for form/%/edit.
 *
 * Allows access if user has 'edit any form' or owns the form
 * and has 'edit own form'.
 */
function _dynamic_form_edit_access($form_id)
{
  global $user;

  if (user_access('edit any form')) {
    return TRUE;
  }

  if (user_access('edit own form')) {
    $created_by = db_select('dynamic_form_forms', 'f')
      ->fields('f', array('created_by'))
      ->condition('id', $form_id)
      ->condition('deleted_at', NULL, 'IS NULL')
      ->execute()
      ->fetchField();
    return $created_by && (int) $created_by === (int) $user->uid;
  }

  return FALSE;
}

/**
 * Access callback for form/%/delete.
 *
 * Allows access if user has 'delete any form' or owns the form
 * and has 'delete own form'.
 */
function _dynamic_form_delete_access($form_id)
{
  global $user;

  if (user_access('delete any form')) {
    return TRUE;
  }

  if (user_access('delete own form')) {
    $created_by = db_select('dynamic_form_forms', 'f')
      ->fields('f', array('created_by'))
      ->condition('id', $form_id)
      ->condition('deleted_at', NULL, 'IS NULL')
      ->execute()
      ->fetchField();
    return $created_by && (int) $created_by === (int) $user->uid;
  }

  return FALSE;
}

/* =====================================================================
   FORM CRUD — SLUG HELPER
   ===================================================================== */

/**
 * Generates a URL-friendly slug from a title.
 *
 * @param string $title
 *   The form title.
 *
 * @return string
 *   A lowercase, hyphenated slug.
 */
function _dynamic_form_generate_slug($title)
{
  // Lowercase, replace non-alphanumeric with hyphens, trim hyphens.
  $slug = drupal_strtolower($title);
  $slug = preg_replace('/[^a-z0-9]+/', '-', $slug);
  $slug = trim($slug, '-');

  // Ensure uniqueness by appending a number if needed.
  $base_slug = $slug;
  $counter = 1;
  while (db_select('dynamic_form_forms', 'f')
    ->fields('f', array('id'))
    ->condition('slug', $slug)
    ->condition('deleted_at', NULL, 'IS NULL')
    ->execute()
    ->fetchField()) {
    $slug = $base_slug . '-' . $counter;
    $counter++;
  }

  return $slug;
}

/* =====================================================================
   FORM ALTERS
   ===================================================================== */

/**
 * Implements hook_form_alter().
 */
function dynamic_form_form_alter(&$form, &$form_state, $form_id) {
  // Override the default Drupal login form error messages.
  if ($form_id == 'user_login' || $form_id == 'user_login_block') {
    $form['#validate'][] = 'dynamic_form_custom_login_error_override';
  }
}

/**
 * Custom validation handler to override the core login error message.
 */
function dynamic_form_custom_login_error_override($form, &$form_state) {
  if (!empty($_SESSION['messages']['error'])) {
    foreach ($_SESSION['messages']['error'] as $key => $message) {
      // Check if the message contains the default Drupal error string.
      if (strpos($message, 'Sorry, unrecognized username or password') !== FALSE) {
        $_SESSION['messages']['error'][$key] = t('Incorrect email or password for login.');
      }
    }
  }
}
