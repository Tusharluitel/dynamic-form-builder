<?php

/**
 * @file
 * Database schema and install/uninstall hooks for the Dynamic Form module.
 */

/**
 * Implements hook_schema().
 */
function dynamic_form_schema()
{
  $schema = array();

  $schema['dynamic_form_forms'] = array(
    'description' => 'Stores form definitions created by the Dynamic Form builder.',
    'fields' => array(
      'id' => array(
        'description' => 'Primary key.',
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ),
      'title' => array(
        'description' => 'The form title.',
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
      ),
      'description' => array(
        'description' => 'Optional description of the form.',
        'type' => 'text',
        'size' => 'medium',
        'not null' => FALSE,
      ),
      'status' => array(
        'description' => 'Publishing status: 0=draft, 1=published, 2=closed.',
        'type' => 'int',
        'size' => 'tiny',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
      ),
      'slug' => array(
        'description' => 'URL-friendly unique identifier for the form.',
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
      ),
      'question_per_page' => array(
        'description' => 'Number of questions to display per page.',
        'type' => 'int',
        'not null' => TRUE,
        'default' => 1,
      ),
      'closes_at' => array(
        'description' => 'Timestamp when the form stops accepting responses. NULL = no expiry.',
        'type' => 'int',
        'not null' => FALSE,
        'default' => NULL,
      ),
      'visibility' => array(
        'description' => 'Access level: p=public, r=restricted, m=members only.',
        'type' => 'char',
        'length' => 1,
        'not null' => TRUE,
        'default' => 'p',
      ),

      'published_at' => array(
        'description' => 'Unix timestamp when the form was published.',
        'type' => 'int',
        'not null' => FALSE,
        'default' => NULL,
      ),
      'opens_at' => array(
        'description' => 'Unix timestamp when the form opens for responses. NULL = no delay.',
        'type' => 'int',
        'not null' => FALSE,
        'default' => NULL,
      ),
      'published_by' => array(
        'description' => 'FK to {users}.uid — form publisher.',
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => FALSE,
        'default' => NULL,
      ),
      'created_by' => array(
        'description' => 'FK to {users}.uid — form author.',
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,

      ),
      'created_at' => array(
        'description' => 'Unix timestamp when the form was created.',
        'type' => 'int',
        'not null' => TRUE,
      ),
      'updated_at' => array(
        'description' => 'Unix timestamp of last update.',
        'type' => 'int',
        'not null' => TRUE,
      ),
      'deleted_at' => array(
        'description' => 'Unix timestamp of when the form was deleted. NULL = not deleted.',
        'type' => 'int',
        'not null' => FALSE,
        'default' => NULL,
      ),
      'deleted_by' => array(
        'description' => 'FK to {users}.uid — form deleter.',
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => FALSE,
        'default' => NULL,
      ),
    ),
    'primary key' => array('id'),
    'unique keys' => array(
      'slug' => array('slug'),
    ),
    'indexes' => array(
      'status' => array('status'),
      'created_by' => array('created_by'),
      'closes_at' => array('closes_at'),
    ),
  );

